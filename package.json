{
  "name": "torra",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check": "biome check .",
    "format": "biome check --write .",
    "validate": "pnpm typecheck && pnpm check && pnpm test && pnpm build",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@commitlint/cli": "^21",
    "@commitlint/config-conventional": "^21",
    "@types/node": "^24",
    "lefthook": "^1",
    "tsup": "^8",
    "tsx": "^4",
    "turbo": "^2",
    "typescript": "^5",
    "vitest": "^2"
  }
}
